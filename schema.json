{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Server Configuration Schema",
  "type": "object",

  "properties": {
    "$schema": {
      "type": "string"
    }
  },
  "patternProperties": {
    "^:\\d+(\\/.*)?$": {
      "type": "object",
      "oneOf": [
        { "$ref": "#/$defs/fileServer" },
        { "$ref": "#/$defs/cgiServer" },
        { "$ref": "#/$defs/redirectServer" }
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "fileServer": {
      "type": "object",
      "properties": {
        "type": { "const": "file server" },
        "root": { "type": "string" },
        "sizeLimit": { "type": "integer", "minimum": 0 },
        "defaultFile": { "type": "string" },
        "directoryListing": { "type": "boolean" },
        "allowed_verbs": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "DELETE", "PATCH", "HEAD", "OPTIONS"]
          },
          "uniqueItems": true
        },
        "errorPages": {
          "type": "object",
          "patternProperties": {
            "^[45]\\d{2}$": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "required": ["type", "root"],
      "additionalProperties": false
    },
    "cgiServer": {
      "type": "object",
      "properties": {
        "type": { "const": "cgi" },
        "root": { "type": "string" }
      },
      "required": ["type", "root"],
      "additionalProperties": false
    },
    "redirectServer": {
      "type": "object",
      "properties": {
        "type": { "const": "redirect" },
        "target": { "type": "string", "format": "uri" }
      },
      "required": ["type", "target"],
      "additionalProperties": false
    }
  }
}
