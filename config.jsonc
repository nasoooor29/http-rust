{
  "schema": "./schema.json",
  ":8080": {
    "type": "file_server",
    "root": "./website1",
    "size_limit": 1024,
    "error_pages": {
      "404": "404.html",
      "500": "500.html"
    },
    "directory_listing": true
  },

  "localhost:8081/upload": {
    // virtual host header
    "type": "file_server",
    "root": "./website2/uploads",
    "size_limit": 1024,
    "allowed_verbs": ["POST"],
    "directory_listing": false
  },

  "0.0.0.0:8081/upload": {
    // virtual host header
    "type": "file_server",
    "root": "./website2/uploads",
    "size_limit": 1024,
    "allowed_verbs": ["POST"],
    "directory_listing": false
  },

  ":8081/whatever": {
    "type": "file_server",
    "root": "./website2/whatever.txt"
  },

  ":8081/redirect-bash": {
    "type": "cgi",
    "root": "./website2/cgi-bin/redirect.sh"
  },

  ":8082": {
    "type": "redirect",
    "target": "http://example.com"
  }
}
